{
  "fear": {
    "description": "Эмоциональная реакция на риск → закрывается эмпатией и гарантиями",
    "patterns": ["не справлюсь", "не смогу", "не потяну", "боюсь", "страшно", "не получится", "провалюсь", "не.*умею"]
  },
  "uncertainty": {
    "description": "Недостаток информации → закрывается чётким описанием",
    "patterns": ["не понимаю.*формат", "что.*получу", "как.*проходит", "что.*входит", "что.*именно", "сколько.*длит", "какой.*результат", "не знаю.*чего.*ожидать"]
  },
  "doubt": {
    "description": "Скептицизм к обещаниям → закрывается доказательствами и кейсами",
    "patterns": ["не верю", "сомневаюсь", "столько.*не стоит", "развод", "обман", "слишком.*хорошо", "звучит.*красиво", "на практике", "а.*реально"]
  }
}
